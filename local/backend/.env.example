# Application
APP_MODE=dev
PORT=3000

# Single User Mode (for local deployment)
# Set to 'true' to enable password-free single user mode
SINGLE_USER_MODE=false
# Optional: Set a local password for single-user mode protection
LOCAL_PASSWORD=

# Database Type: 'mysql' or 'sqlite'
DB_TYPE=mysql

# MySQL Configuration (used when DB_TYPE=mysql)
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=sjblp
DB_DATABASE=code_notebook

# SQLite Configuration (used when DB_TYPE=sqlite)
SQLITE_PATH=./data/quillcode.db

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Elasticsearch (only used when DB_TYPE=mysql)
ELASTICSEARCH_NODE=http://localhost:9200
ELASTICSEARCH_INDEX=articles

# Ollama (Dev mode only)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
